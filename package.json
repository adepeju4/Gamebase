{
  "name": "game-library",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "Orefejo Adepeju",
  "license": "ISC",
  "scripts": {
    "build": "npx tsc -p tsconfig.json && vite build",
    "build:server": "npx tsc -p server/tsconfig.json",
    "vercel-build": "npm run build",
    "vercel-install": "npm install --legacy-peer-deps",
    "dev:client": "vite",
    "dev:server": "nodemon --watch server --ext ts,js --exec \"node --loader ts-node/esm server/server.ts\"",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "lint": "eslint . --ext ts,tsx,js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "gulp-prod": "node_modules/.bin/gulp prod",
    "gulp-dev": "node_modules/.bin/gulp dev",
    "tsc": "npx tsc -p tsconfig.json",
    "tsc:server": "npx tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@types/jsonwebtoken": "^9.0.9",
    "antd": "^5.15.0",
    "axios": "^0.27.2",
    "bcrypt": "^5.0.1",
    "browserify": "^17.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "easy-peasy": "^5.0.4",
    "express": "^4.12.3",
    "file-loader": "^6.2.0",
    "framer-motion": "^6.3.11",
    "gulp": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "mongoose": "^6.3.8",
    "next-themes": "^0.4.4",
    "prop-types": "^15.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.54.2",
    "react-icons": "^4.4.0",
    "react-router-dom": "^6.22.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.1",
    "stream-chat": "^8.19.0",
    "stream-chat-react": "^11.11.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "universal-cookie": "^4.0.4",
    "uuid": "^8.3.2",
    "vite": "^5.1.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@shadcn/ui": "^0.0.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^6.5.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.34.0",
